      <column caption='ID NAMES' datatype='string' name='[Calculation_0603963604537346]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Customer ID]+ &quot;-&quot; +[Customer Name]' />
      </column>
      <column caption='High Low Sales' datatype='string' name='[Calculation_0603963606147075]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF sum([Sales])&gt;100000 THEN &quot;High&quot; ELSE &quot;Low&quot; END' />
      </column>
      <column caption='Profit Loss Sales' datatype='string' name='[Calculation_0603963609440261]' role='measure' type='nominal'>
        <calculation class='tableau' formula='if sum([Profit])&gt;0 THEN &quot;Profit&quot; ELSE &quot;Loss&quot; END' />
      </column>
      <column caption='Years' datatype='date' datatype-customized='true' name='[Calculation_0603963613523974]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='DATE(DATEPARSE ( &quot;yyyy&quot;, STR(YEAR([Order Date])) )) ' />
      </column>
      <column caption='Rankwise' datatype='integer' name='[Calculation_0603963620528136]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(sum([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_0691924881768448]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Profit]/[Sales]' />
      </column>
      <column caption='Sales_compare' datatype='string' name='[Calculation_0691924887728129]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Sales])&lt;[Parameters].[Parameter 1] THEN &quot;OK&quot; ELSE &quot;GREAT&quot; END' />
      </column>
      <column caption='Selected Measure Value' datatype='real' name='[Calculation_0691924895764483]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 3]&#13;&#10;when &quot;Sales&quot; then sum([Sales])&#13;&#10;when &quot;Profit&quot; then sum([Profit])&#13;&#10;when &quot;Quantity&quot; then sum([Quantity])&#13;&#10;when &quot;Discount&quot; then sum([Discount])&#13;&#10;END' />
      </column>
